{
  "name": "cypress-automation-framework",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cy:open": "cypress open --browser chrome",
    "cy:run": "CYPRESS_NO_COMMAND_LOG=1 cypress run --browser chrome",
    "cy:open:test": "CYPRESS_ENV=test cypress open --browser chrome",
    "cy:run:test": "CYPRESS_ENV=test CYPRESS_NO_COMMAND_LOG=1 cypress run --browser chrome",
    "cy:open:staging": "CYPRESS_ENV=staging cypress open --browser chrome",
    "cy:run:staging": "CYPRESS_ENV=staging CYPRESS_NO_COMMAND_LOG=1 cypress run --browser chrome",
    "cy:open:dev": "CYPRESS_ENV=dev cypress open --browser chrome",
    "cy:run:dev": "CYPRESS_ENV=dev CYPRESS_NO_COMMAND_LOG=1 cypress run --browser chrome",
    "cy:open:production": "CYPRESS_ENV=production cypress open --browser chrome",
    "cy:run:production": "CYPRESS_ENV=production CYPRESS_NO_COMMAND_LOG=1 cypress run --browser chrome",
    "test": "npm run cy:run"
  },
  "devDependencies": {
    "@4tw/cypress-drag-drop": "^2.3.1",
    "cypress": "^15.16.0",
    "cypress-iframe": "^1.0.1",
    "cypress-real-events": "^1.15.0",
    "mochawesome": "^7.1.4"
  }
}
